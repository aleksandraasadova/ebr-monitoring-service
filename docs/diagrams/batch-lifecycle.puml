@startuml batch-lifecycle
title Жизненный цикл производственной партии

skinparam backgroundColor #f7f9fc
skinparam state {
    BackgroundColor #dbeafe
    BorderColor     #12205c
    FontColor       #12205c
    FontSize        12
    ArrowColor      #12205c
    ArrowThickness  1.5
}
skinparam roundcorner 0

[*] --> ЗАРЕГИСТРИРОВАНА : POST /api/v1/batches\nОператор вводит рецептуру и объём

ЗАРЕГИСТРИРОВАНА --> ВЗВЕШИВАНИЕ : Оператор начинает\nвзвешивание ингредиентов
note right of ЗАРЕГИСТРИРОВАНА
  Создаётся batch_code,
  фиксируется registered_by из JWT
end note

ВЗВЕШИВАНИЕ --> В_ПРОИЗВОДСТВЕ : Все ингредиенты\nзафиксированы и приняты
ВЗВЕШИВАНИЕ --> ОТКЛОНЕНА : Критическое отклонение\nмассы ингредиента
note right of ВЗВЕШИВАНИЕ
  MQTT-телеметрия от весов,
  сравнение с рецептурой,
  алерт при откл. > допуска
end note

В_ПРОИЗВОДСТВЕ --> КОНТРОЛЬ_КАЧЕСТВА : Все шаги процесса\nзавершены
В_ПРОИЗВОДСТВЕ --> ОТКЛОНЕНА : Отклонение параметров\nпроцесса (T, pH, rpm)
note right of В_ПРОИЗВОДСТВЕ
  Шаги: нагрев фаз A/B,
  гомогенизация, охлаждение,
  добавление фазы C
end note

КОНТРОЛЬ_КАЧЕСТВА --> ЗАВЕРШЕНА : ОКК подтвердил\nсоответствие
КОНТРОЛЬ_КАЧЕСТВА --> ОТКЛОНЕНА : Несоответствие\nпараметров

ЗАВЕРШЕНА --> [*]
note right of ЗАВЕРШЕНА
  Автоматически формируется
  итоговый протокол партии
end note

ОТКЛОНЕНА --> [*]
note right of ОТКЛОНЕНА
  Аудит-запись сохраняется
  через триггер PostgreSQL
end note

@enduml
